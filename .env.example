# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored — never commit real credentials.

# The "client_email" from your Google service account JSON.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-bot@your-project.iam.gserviceaccount.com

# The "private_key" from your Google service account JSON.
# Keep the surrounding double quotes and the literal "\n" sequences;
# Next.js will read it as a single string and the app converts \n back to newlines.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEET_ID=your-spreadsheet-id
